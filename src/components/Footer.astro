---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-100 bg-slate-50">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="grid gap-8 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="flex items-center">
          <img src="/logo-zentivy.png" alt="Zentivy" class="h-8 w-auto" />
        </div>
        <p class="mt-3 max-w-sm text-sm text-slate-500">
          Software de inventario, facturación y ventas en la nube para negocios
          en {SITE.pais}. Simple, rápido y con agente de WhatsApp opcional.
        </p>
      </div>

      <div>
        <h2 class="text-xs font-bold uppercase tracking-wide text-slate-400">
          Producto
        </h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li><a class="hover:text-brand" href="/#funciones">Funciones</a></li>
          <li><a class="hover:text-brand" href="/#agente">Agente IA</a></li>
          <li><a class="hover:text-brand" href="/#precios">Precios</a></li>
          <li><a class="hover:text-brand" href={SITE.appUrl}>Iniciar sesión</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-xs font-bold uppercase tracking-wide text-slate-400">
          Legal y contacto
        </h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li>
            <a class="hover:text-brand" href="/politica-privacidad"
              >Política de privacidad</a
            >
          </li>
          <li><a class="hover:text-brand" href="/terminos">Términos</a></li>
          <li>
            <a class="hover:text-brand" href={SITE.whatsapp} rel="nofollow"
              >WhatsApp</a
            >
          </li>
          <li>
            <a class="hover:text-brand" href={`mailto:${SITE.email}`}
              >{SITE.email}</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-10 border-t border-slate-200 pt-6 text-xs text-slate-400"
    >
      © {year} Zentivy. Hecho en {SITE.ciudad}, {SITE.pais}.
    </div>
  </div>
</footer>
