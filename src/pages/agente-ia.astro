---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

const seoTitle = 'Agente IA de WhatsApp para PYMES — Zentivy Colombia';
const seoDesc = 'Automatiza tus ventas en WhatsApp con un agente de inteligencia artificial por $59.900/mes. Responde 24/7, consulta catálogo y stock en tiempo real, y registra ventas.';
---

<Layout title={seoTitle} description={seoDesc}>
  <Header />

  <main class="bg-slate-50 text-slate-900 relative overflow-hidden">
    <!-- Efecto de luces de fondo (Versión Clara) -->
    <div class="absolute inset-0 z-0 opacity-40 pointer-events-none">
      <div class="absolute top-[-20%] left-[-10%] h-[600px] w-[600px] rounded-full bg-brand-light/20 blur-[150px]"></div>
      <div class="absolute bottom-[20%] right-[-10%] h-[600px] w-[600px] rounded-full bg-brand-light/30 blur-[150px]"></div>
    </div>

    <!-- HERO / SECCIÓN PRINCIPAL -->
    <section class="relative z-10 mx-auto max-w-6xl px-5 py-20 lg:py-28">
      <div class="grid gap-12 items-center lg:grid-cols-12">
        <div class="lg:col-span-7 text-left reveal">
          <span class="rounded-full bg-brand/10 border border-brand/20 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-brand">
            Add-on opcional para tu negocio
          </span>
          <h1 class="mt-6 text-4xl font-black leading-tight tracking-tight text-slate-900 md:text-5xl lg:text-6xl">
            Tu WhatsApp vende solo con un <span class="bg-gradient-to-r from-brand to-brand-light bg-clip-text text-transparent">Agente de IA</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-slate-600">
            Conecta la inteligencia artificial directamente al WhatsApp de tu negocio. El agente consulta tu inventario de Zentivy en tiempo real, atiende consultas, analiza imágenes (como comprobantes o fotos de productos), entiende notas de voz y concreta ventas sin que muevas un dedo.
          </p>

          <div class="mt-8 flex flex-wrap gap-4 items-center">
            <div class="text-3xl font-black text-slate-900">$59.900<span class="text-sm font-medium text-slate-500"> COP / mes</span></div>
            <div class="text-xs text-slate-500 border-l border-slate-200 pl-4 py-1">Contratado de forma adicional a cualquier plan Zentivy.</div>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href={SITE.whatsapp} rel="nofollow" class="rounded-xl bg-brand px-8 py-4 text-center text-base font-bold text-white shadow-lg shadow-brand/20 transition-all hover:bg-brand-dark hover:-translate-y-0.5">
              Solicitar Agente IA en WhatsApp
            </a>
            <a href="#como-funciona" class="rounded-xl border-2 border-slate-200 bg-white px-8 py-4 text-center text-base font-bold text-slate-700 transition-all hover:bg-slate-50 hover:border-brand hover:text-brand hover:-translate-y-0.5">
              ¿Cómo funciona?
            </a>
          </div>
        </div>

        <div class="lg:col-span-5 flex justify-center reveal w-full">
          <!-- Mockup Celular Realista -->
          <div class="relative w-full max-w-[320px] h-[580px] bg-slate-950 rounded-[44px] p-3 shadow-2xl border-[10px] border-slate-800 ring-4 ring-slate-900/5 overflow-hidden flex flex-col text-left select-none">
            <!-- Dynamic Island / Parlante de pantalla -->
            <div class="absolute top-4 left-1/2 -translate-x-1/2 w-28 h-5 bg-slate-950 rounded-full z-30 flex items-center justify-center border border-white/5 shadow-inner">
              <div class="w-10 h-1 bg-white/10 rounded-full"></div>
            </div>
            
            <!-- Pantalla interna -->
            <div class="flex-1 bg-slate-900 rounded-[34px] overflow-hidden flex flex-col p-4 pt-8 relative">
              
              <!-- Cabecera de chat -->
              <div class="flex items-center gap-3 border-b border-white/5 pb-3 mb-3">
                <div class="h-9 w-9 rounded-full bg-brand/10 border border-brand/20 flex items-center justify-center font-bold text-brand text-xs">IA</div>
                <div>
                  <div class="text-xs font-bold text-white">Agente Zentivy</div>
                  <div class="text-[10px] text-emerald-400" id="ia-agent-status">● En línea (24/7)</div>
                </div>
              </div>

              <!-- Mensajes del chat con scroll oculto y animaciones de burbuja -->
              <div class="flex-1 space-y-2.5 overflow-hidden pr-0.5 no-scrollbar text-xs" id="ia-chat-container">
                <div class="chat-bubble opacity-0 max-w-[85%] rounded-2xl rounded-tl-sm bg-white/10 px-3 py-2 text-[11px] text-slate-200 transition-all duration-300 transform translate-y-2">
                  Hola, ¿tienen disco de estado sólido de 480GB?
                </div>
                
                <div class="chat-bubble opacity-0 ml-auto max-w-[85%] rounded-2xl rounded-tr-sm bg-brand p-1 text-white shadow-md transition-all duration-300 transform translate-y-2 flex flex-col gap-1">
                  <div class="relative w-full h-[95px] rounded-lg overflow-hidden border border-white/10 bg-[#f3f4f6]">
                    <img src="/zentivy_ssd.png" alt="Disco Sólido Zentivy" class="w-full h-full object-contain" />
                  </div>
                  <span class="px-2 pb-1 block text-xs text-[11px]">¡Hola! 😊 Sí, tenemos el Disco Sólido Zentivy de 480GB por $145.000 COP. Nos quedan 8 unidades en Sede Centro. ¿Te lo aparto?</span>
                </div>

                <div class="chat-bubble opacity-0 max-w-[85%] rounded-2xl rounded-tl-sm bg-white/10 px-3 py-2 text-[11px] text-slate-200 transition-all duration-300 transform translate-y-2">
                  Sí, me gusta. ¿Cómo pago?
                </div>

                <div class="chat-bubble opacity-0 ml-auto max-w-[85%] rounded-2xl rounded-tr-sm bg-brand px-3 py-2 text-[11px] text-white shadow-md transition-all duration-300 transform translate-y-2">
                  ¡Excelente! He apartado 1 unidad. Puedes pagar por Nequi al 320 000 0000 o transferir a Bancolombia. Envíame el comprobante por aquí.
                </div>
              </div>

              <div class="mt-3 border-t border-white/5 pt-3 text-[10px] text-center text-slate-500">
                Atendido automáticamente en WhatsApp
              </div>
            </div>
          </div>

          <script>
            const initIaChatSimulation = () => {
              const chatContainer = document.getElementById('ia-chat-container');
              const statusText = document.getElementById('ia-agent-status');
              if (!chatContainer || !statusText) return;

              const bubbles = chatContainer.querySelectorAll('.chat-bubble');
              let currentStep = 0;
              let timeoutId: number;

              const showMessage = () => {
                if (currentStep >= bubbles.length) {
                  // End of conversation: wait 6 seconds and restart
                  timeoutId = setTimeout(() => {
                    bubbles.forEach(b => {
                      b.classList.add('opacity-0', 'translate-y-2');
                      b.classList.remove('opacity-100', 'translate-y-0');
                    });
                    currentStep = 0;
                    statusText.innerHTML = '● En línea (24/7)';
                    statusText.className = 'text-[10px] text-emerald-400';
                    chatContainer.scrollTop = 0;
                    showMessage();
                  }, 6000) as unknown as number;
                  return;
                }

                const currentBubble = bubbles[currentStep];
                const isAgent = currentBubble.classList.contains('ml-auto');
                
                if (isAgent) {
                  // Agent is typing status
                  statusText.innerHTML = 'Escribiendo...';
                  statusText.className = 'text-[10px] text-brand-light animate-pulse font-medium';
                  
                  // Wait 1.8 seconds to show the message
                  timeoutId = setTimeout(() => {
                    statusText.innerHTML = '● En línea (24/7)';
                    statusText.className = 'text-[10px] text-emerald-400';
                    
                    currentBubble.classList.remove('opacity-0', 'translate-y-2');
                    currentBubble.classList.add('opacity-100', 'translate-y-0');
                    
                    // Scroll to bottom
                    chatContainer.scrollTo({
                      top: chatContainer.scrollHeight,
                      behavior: 'smooth'
                    });
                    
                    currentStep++;
                    // Wait 2.5 seconds before next message
                    timeoutId = setTimeout(showMessage, 2500) as unknown as number;
                  }, 1800) as unknown as number;
                } else {
                  // Customer message: appears faster
                  timeoutId = setTimeout(() => {
                    currentBubble.classList.remove('opacity-0', 'translate-y-2');
                    currentBubble.classList.add('opacity-100', 'translate-y-0');
                    
                    // Scroll to bottom
                    chatContainer.scrollTo({
                      top: chatContainer.scrollHeight,
                      behavior: 'smooth'
                    });
                    
                    currentStep++;
                    // Wait 1.8 seconds before next message
                    timeoutId = setTimeout(showMessage, 1800) as unknown as number;
                  }, 1000) as unknown as number;
                }
              };

              const startSimulation = () => {
                bubbles.forEach(b => {
                  b.classList.add('opacity-0', 'translate-y-2');
                  b.classList.remove('opacity-100', 'translate-y-0');
                });
                currentStep = 0;
                statusText.innerHTML = '● En línea (24/7)';
                statusText.className = 'text-[10px] text-emerald-400';
                chatContainer.scrollTop = 0;
                showMessage();
              };

              startSimulation();
            };

            initIaChatSimulation();
            document.addEventListener('astro:after-swap', initIaChatSimulation);
          </script>
        </div>
      </div>
    </section>

    <!-- CARACTERÍSTICAS CLAVE -->
    <section id="como-funciona" class="scroll-mt-20 border-t border-slate-200 bg-white py-20 relative z-10">
      <div class="mx-auto max-w-6xl px-5">
        <div class="mx-auto max-w-3xl text-center reveal">
          <h2 class="text-3xl font-black tracking-tight text-slate-900 md:text-4xl">
            ¿Qué hace al Agente de IA diferente?
          </h2>
          <p class="mt-4 text-lg text-slate-600">
            Un asistente inteligente conectado directamente al núcleo de tu negocio.
          </p>
        </div>

        <div class="mt-14 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          <!-- Tarjeta 1 -->
          <div class="rounded-2xl border border-slate-100 bg-slate-50/50 p-8 hover:border-brand/20 hover:bg-white hover:shadow-md transition-all reveal">
            <div class="text-3xl">⏰</div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">Vendedor Activo 24/7</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              No pierdas ventas por responder tarde. La IA atiende a tus clientes los domingos, en la noche o en horas pico de forma inmediata.
            </p>
          </div>

          <!-- Tarjeta 2 -->
          <div class="rounded-2xl border border-slate-100 bg-slate-50/50 p-8 hover:border-brand/20 hover:bg-white hover:shadow-md transition-all reveal reveal-delay-1">
            <div class="text-3xl">📊</div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">Reportes en Tiempo Real</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              El agente te mantiene informado sobre lo que ocurre. Te reporta detalles de las ventas generadas y las consultas más recurrentes.
            </p>
          </div>

          <!-- Tarjeta 3 -->
          <div class="rounded-2xl border border-slate-100 bg-slate-50/50 p-8 hover:border-brand/20 hover:bg-white hover:shadow-md transition-all reveal reveal-delay-2">
            <div class="text-3xl">👁️</div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">IA Multimodal</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              El agente puede entender notas de voz de tus clientes y analizar imágenes (como fotos de productos para buscar en stock o fotos de comprobantes de pago Nequi/Bancolombia) de forma automática.
            </p>
          </div>

          <!-- Tarjeta 4 -->
          <div class="rounded-2xl border border-slate-100 bg-slate-50/50 p-8 hover:border-brand/20 hover:bg-white hover:shadow-md transition-all reveal">
            <div class="text-3xl">🎛️</div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">Panel de Clientes en Zentivy</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              Tú controlas la IA. Cuentas con un panel administrativo dentro de Zentivy donde puedes activar o desactivar qué clientes son atendidos por el agente.
            </p>
          </div>

          <!-- Tarjeta 5 -->
          <div class="rounded-2xl border border-slate-100 bg-slate-50/50 p-8 hover:border-brand/20 hover:bg-white hover:shadow-md transition-all reveal reveal-delay-1">
            <div class="text-3xl">💬</div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">Mensajería Nativa</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              A diferencia de otros sistemas engorrosos, <strong>los mensajes no se reportan en Telegram</strong>. Todo se maneja directamente en WhatsApp y queda consolidado dentro de tu plataforma Zentivy.
            </p>
          </div>

          <!-- Tarjeta 6 -->
          <div class="rounded-2xl border border-slate-100 bg-slate-50/50 p-8 hover:border-brand/20 hover:bg-white hover:shadow-md transition-all reveal reveal-delay-2">
            <div class="text-3xl">📉</div>
            <h3 class="mt-4 text-xl font-bold text-slate-900">Sincronización Total</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              Si un producto se agota en tu local, la IA deja de ofrecerlo inmediatamente en WhatsApp. Control estricto para evitar compromisos sin stock.
            </p>
          </div>
        </div>
      </div>
    </section>



    <!-- COMPARATIVO: FUERA DEL AGENTE -->
    <section class="mx-auto max-w-5xl px-5 py-20 relative z-10">
      <div class="rounded-3xl border border-slate-200 bg-slate-900 p-8 md:p-12 relative overflow-hidden shadow-xl text-white reveal">
        <div class="absolute -left-10 -bottom-10 h-40 w-40 rounded-full bg-brand/20 blur-2xl"></div>
        
        <h2 class="text-2xl font-black tracking-tight text-white md:text-3xl">
          ¿Qué tiene Zentivy fuera del Agente de WhatsApp?
        </h2>
        <p class="mt-3 text-slate-300">
          El agente de IA es una excelente extensión, pero el corazón de Zentivy es un sistema administrativo sumamente robusto que incluye de forma nativa:
        </p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 md:grid-cols-3 text-sm text-slate-300">
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Gestión completa de clientes</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Control de activos del negocio</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Multi-sede e inventarios aislados</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Multi-usuario con roles de seguridad</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Estadísticas de ventas por sedes</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Descarga de reportes mensuales</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Estadísticas y compras de clientes</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Top de productos más vendidos</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Gráficos interactivos anuales</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Registro y cuentas de proveedores</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Escáner de código de barras</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-light font-bold">✓</span>
            <span>Impresión directa de códigos de barra</span>
          </div>
        </div>

        <div class="mt-8 pt-6 border-t border-white/10 text-center sm:text-left">
          <a href="/funciones" class="text-sm font-bold text-brand-light hover:text-white transition-colors hover:underline">
            Conoce todas las funciones administrativas aquí &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- FAQS ESPECIFICAS DEL AGENTE -->
    <section class="border-t border-slate-200 bg-slate-100/50 py-20 relative z-10">
      <div class="mx-auto max-w-3xl px-5 reveal">
        <h2 class="text-center text-3xl font-black tracking-tight text-slate-900">Preguntas sobre el Agente IA</h2>
        
        <div class="mt-12 space-y-4">
          <div class="faq-item group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <button class="faq-trigger flex w-full cursor-pointer items-center justify-between text-base font-bold text-slate-900 text-left focus:outline-none">
              <span>¿Cómo se conecta con mi WhatsApp?</span>
              <span class="faq-icon text-brand transition-transform font-bold text-xl">+</span>
            </button>
            <div class="faq-content">
              <div class="overflow-hidden">
                <p class="pt-3 text-sm leading-relaxed text-slate-600">
                  Es muy sencillo. Se realiza mediante el escaneo de un código QR desde la sección de Dispositivos Vinculados en tu aplicación de WhatsApp (de la misma forma que conectas WhatsApp Web). No requieres configuraciones técnicas complejas ni contratar APIs externas costosas.
                </p>
              </div>
            </div>
          </div>

          <div class="faq-item group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <button class="faq-trigger flex w-full cursor-pointer items-center justify-between text-base font-bold text-slate-900 text-left focus:outline-none">
              <span>¿Por qué los mensajes no llegan a Telegram?</span>
              <span class="faq-icon text-brand transition-transform font-bold text-xl">+</span>
            </button>
            <div class="faq-content">
              <div class="overflow-hidden">
                <p class="pt-3 text-sm leading-relaxed text-slate-600">
                  Queremos que tu flujo de trabajo sea lo más simple y privado posible. El agente de IA opera de forma integrada en WhatsApp. La información de las ventas y las interacciones con los clientes se controlan desde tu panel administrativo de Zentivy, evitando tener que usar canales externos como Telegram que dividen tus notificaciones y datos.
                </p>
              </div>
            </div>
          </div>

          <div class="faq-item group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <button class="faq-trigger flex w-full cursor-pointer items-center justify-between text-base font-bold text-slate-900 text-left focus:outline-none">
              <span>¿Puedo desactivar el agente para ciertos clientes?</span>
              <span class="faq-icon text-brand transition-transform font-bold text-xl">+</span>
            </button>
            <div class="faq-content">
              <div class="overflow-hidden">
                <p class="pt-3 text-sm leading-relaxed text-slate-600">
                  Sí. Entendemos que hay clientes especiales o mayoristas con los que prefieres tener un trato 100% humano. En tu panel administrativo en Zentivy tendrás un interruptor sencillo para activar o desactivar la atención automática del agente de IA para cada cliente específico.
                </p>
              </div>
            </div>
          </div>

          <div class="faq-item group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <button class="faq-trigger flex w-full cursor-pointer items-center justify-between text-base font-bold text-slate-900 text-left focus:outline-none">
              <span>¿Necesito tener mi computador encendido para que funcione?</span>
              <span class="faq-icon text-brand transition-transform font-bold text-xl">+</span>
            </button>
            <div class="faq-content">
              <div class="overflow-hidden">
                <p class="pt-3 text-sm leading-relaxed text-slate-600">
                  No. El agente opera 100% en la nube en nuestros servidores. Una vez vinculado tu WhatsApp, responderá las 24 horas del día aunque tu computador o celular estén completamente apagados o sin conexión.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script>
      const initFaqs = () => {
        const triggers = document.querySelectorAll('.faq-trigger');
        triggers.forEach(trigger => {
          trigger.addEventListener('click', () => {
            const item = trigger.closest('.faq-item');
            if (!item) return;
            const isActive = item.classList.contains('active');
            
            // Close other FAQs
            document.querySelectorAll('.faq-item').forEach(otherItem => {
              otherItem.classList.remove('active');
            });

            if (!isActive) {
              item.classList.add('active');
            }
          });
        });
      };
      
      initFaqs();
      document.addEventListener('astro:after-swap', initFaqs);
    </script>

    <!-- CTA FINAL -->
    <section class="mx-auto max-w-6xl px-5 py-20 relative z-10">
      <div class="rounded-3xl border border-brand/20 bg-gradient-to-br from-brand/5 via-white to-white p-8 md:p-16 text-center relative overflow-hidden shadow-lg reveal">
        <div class="absolute -right-20 -bottom-20 h-60 w-60 rounded-full bg-brand-light/10 blur-3xl pointer-events-none"></div>
        <h2 class="text-3xl font-black tracking-tight md:text-4xl text-slate-900 relative z-10">¿Listo para tener a tu mejor vendedor activo 24/7?</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-slate-600 relative z-10">
          Escríbenos para solicitar la demostración y activar el add-on del agente de IA en tu número de WhatsApp.
        </p>
        <a href={SITE.whatsapp} rel="nofollow" class="mt-8 inline-flex rounded-xl bg-brand px-8 py-4 text-base font-bold text-white shadow-md transition-all hover:bg-brand-dark hover:-translate-y-0.5 relative z-10">
          Activar Agente IA ahora ($59.900/mes)
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
