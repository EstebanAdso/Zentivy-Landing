---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

const seoTitle = 'Planes y Precios Zentivy — Software POS de Facturación e Inventario';
const seoDesc = 'Planes económicos para PYMES en Colombia. Básico $20k/mes, Pro $40k/mes y Star $60k/mes. Pruébalo gratis por 15 días. Add-on Agente IA por $59.900/mes.';

const planes = [
  {
    nombre: 'Básico',
    precio: '$20.000',
    periodo: '/mes',
    desc: 'Para empezar. Incluye 15 días gratis.',
    badge: '15 días gratis',
    badgeDesc: 'Usuario nuevo · sin pago',
    features: [
      'Hasta 1 usuario',
      'Sedes ilimitadas',
      '500 clientes',
      '200 facturas/mes',
      '500 productos'
    ],
    cta: 'Pagar $20.000',
    destacado: false
  },
  {
    nombre: 'Pro',
    precio: '$40.000',
    periodo: '/mes',
    desc: 'Para negocios en crecimiento.',
    badge: '+15 días gratis',
    badgeDesc: 'Usuario nuevo · con tu compra',
    features: [
      'Hasta 3 usuarios',
      'Sedes ilimitadas',
      '2.000 clientes',
      '2.000 facturas/mes',
      '3.000 productos'
    ],
    cta: 'Pagar $40.000',
    destacado: true
  },
  {
    nombre: 'Star',
    precio: '$60.000',
    periodo: '/mes',
    desc: 'Todo ilimitado, sin límites.',
    badge: '+15 días gratis',
    badgeDesc: 'Usuario nuevo · con tu compra',
    features: [
      'Hasta 10 usuarios',
      'Sedes ilimitadas',
      'Clientes ilimitados',
      'Facturas ilimitadas',
      'Productos ilimitados'
    ],
    cta: 'Pagar $60.000',
    destacado: false
  },
  {
    nombre: 'Personalizado',
    precio: 'A tu medida',
    periodo: '',
    desc: 'A tu medida. Hablemos por WhatsApp.',
    badge: 'Soporte VIP',
    badgeDesc: 'Acompañamiento directo',
    features: [
      'Usuarios a tu necesidad',
      'Sedes a tu necesidad',
      'Clientes y facturas a medida',
      'Funciones especiales',
      'Acompañamiento directo'
    ],
    cta: 'Escríbenos',
    destacado: false
  }
];
---

<Layout title={seoTitle} description={seoDesc}>
  <Header />

  <main class="bg-slate-50 py-16">
    <div class="mx-auto max-w-6xl px-5">
      <!-- HEADER SECCIÓN -->
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <span class="rounded-full bg-brand/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-brand">Precios Transparentes</span>
        <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-900 md:text-5xl">
          El plan perfecto para el tamaño de tu negocio
        </h1>
        <p class="mt-4 text-lg text-slate-600">
          Empieza hoy y controla tu inventario, ventas y clientes. Todos los planes incluyen acceso inmediato. Precios en pesos colombianos (COP).
        </p>
      </div>

      <!-- GRID PLANES -->
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 items-stretch">
        {planes.map((p, i) => (
          <div class={`flex flex-col rounded-3xl border bg-white p-7 relative transition-all reveal ${i === 1 ? 'reveal-delay-1' : i === 2 ? 'reveal-delay-2' : i === 3 ? 'reveal-delay-3' : ''} ${
            p.destacado 
              ? 'border-brand shadow-xl ring-2 ring-brand/10 scale-105 z-10' 
              : 'border-slate-200 hover:border-slate-300 shadow-sm'
          }`}>
            {p.destacado && (
              <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-brand px-4 py-1 text-xs font-extrabold uppercase tracking-widest text-white shadow-md">
                Popular
              </span>
            )}
            
            <div class="mb-5">
              <h3 class="text-xl font-black text-slate-900">{p.nombre}</h3>
              <p class="mt-2 text-xs text-slate-500 min-h-[32px]">{p.desc}</p>
            </div>

            <!-- PRECIO -->
            <div class="mb-6">
              <div class="flex items-baseline gap-1">
                <span class="text-3xl font-black tracking-tight text-slate-900">{p.precio}</span>
                <span class="text-sm font-semibold text-slate-400">{p.periodo}</span>
              </div>
            </div>

            <!-- REGALO / BADGE -->
            <div class="mb-6 rounded-2xl bg-emerald-500/5 border border-emerald-500/10 p-3 text-center">
              <div class="text-xs font-bold text-emerald-700">🎁 {p.badge}</div>
              <div class="text-[10px] text-slate-400 font-medium">{p.badgeDesc}</div>
            </div>

            <!-- CARACTERÍSTICAS -->
            <ul class="space-y-3 mb-8 flex-1 text-sm text-slate-600 border-t border-slate-100 pt-6">
              {p.features.map((f) => (
                <li class="flex items-start gap-2.5">
                  <span class="text-brand font-bold text-xs mt-0.5">✓</span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            <!-- BOTÓN CTA -->
            <a 
              href={p.nombre === 'Personalizado' ? SITE.whatsapp : `${SITE.appUrl}/registro?plan=${p.nombre.toLowerCase()}`}
              class={`block w-full py-3.5 rounded-xl text-center text-sm font-bold transition-all ${
                p.destacado 
                  ? 'bg-brand text-white hover:bg-brand-dark shadow-lg shadow-brand/20 hover:-translate-y-0.5' 
                  : p.nombre === 'Personalizado'
                    ? 'border-2 border-slate-700 text-slate-800 hover:bg-slate-900 hover:text-white hover:-translate-y-0.5'
                    : 'border-2 border-slate-200 text-slate-700 hover:border-brand hover:text-brand hover:-translate-y-0.5'
              }`}
            >
              {p.cta}
            </a>
          </div>
        ))}
      </div>

      <!-- SECCIÓN ADD-ON AGENTE IA -->
      <div class="mt-20 rounded-3xl border border-brand/20 bg-gradient-to-br from-brand/5 via-white to-white p-8 md:p-12 shadow-lg max-w-4xl mx-auto relative overflow-hidden reveal">
        <div class="absolute -right-20 -bottom-20 h-60 w-60 rounded-full bg-brand-light/10 blur-3xl pointer-events-none"></div>
        <div class="grid md:grid-cols-12 gap-8 items-center">
          <div class="md:col-span-8">
            <span class="rounded-full bg-brand/10 px-3.5 py-1 text-xs font-bold uppercase tracking-wider text-brand">
              Automatización Exclusiva
            </span>
            <h2 class="mt-4 text-2xl font-black text-slate-900 md:text-3xl">
              Agente IA de WhatsApp
            </h2>
            <p class="mt-3 text-slate-600 leading-relaxed text-sm">
              Súmale un vendedor inteligente a tu plan. Atiende a tus clientes las 24 horas, consulta el catálogo y stock directamente en tu base de datos de Zentivy y registra reservas.
            </p>
            <ul class="mt-5 grid grid-cols-2 gap-3 text-xs font-semibold text-slate-700">
              <li class="flex items-center gap-2">🟢 Ventas automáticas 24/7</li>
              <li class="flex items-center gap-2">🟢 Sincronizado a Zentivy</li>
              <li class="flex items-center gap-2">🟢 Control desde tu panel</li>
              <li class="flex items-center gap-2">🟢 Sin reportes en Telegram</li>
            </ul>
          </div>
          <div class="md:col-span-4 text-center md:text-right border-t md:border-t-0 md:border-l border-slate-200 pt-6 md:pt-0 md:pl-8">
            <div class="text-xs text-slate-400 font-bold uppercase tracking-wide">Precio Adicional</div>
            <div class="text-3xl font-black text-slate-900 mt-1">$59.900</div>
            <div class="text-xs text-slate-400 font-semibold uppercase">COP / mes</div>
            <a 
              href="/agente-ia"
              class="mt-5 inline-block w-full bg-brand text-white text-xs font-bold py-3 px-4 rounded-xl shadow-md transition-all hover:bg-brand-dark hover:-translate-y-0.5"
            >
              Ver detalles del Agente &rarr;
            </a>
          </div>
        </div>
      </div>

      <!-- FAQ PRECIOS -->
      <div class="mt-20 max-w-3xl mx-auto reveal">
        <h3 class="text-2xl font-black text-slate-900 text-center mb-8">Preguntas sobre facturación</h3>
        <div class="space-y-4">
          <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm">
            <h4 class="font-bold text-slate-900">¿Puedo cambiar de plan en cualquier momento?</h4>
            <p class="mt-2 text-sm text-slate-600">Sí, puedes subir o bajar de plan cuando lo necesites directamente desde tu panel administrativo de Zentivy. Los cambios se calcularán a prorrata de tu fecha de corte.</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm">
            <h4 class="font-bold text-slate-900">¿Qué métodos de pago aceptan?</h4>
            <p class="mt-2 text-sm text-slate-600">Aceptamos transferencias por Nequi, Daviplata, tarjetas de crédito y PSE a través de nuestra pasarela de pagos integrada para Colombia.</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm">
            <h4 class="font-bold text-slate-900">¿Tengo cobros ocultos o comisiones por venta?</h4>
            <p class="mt-2 text-sm text-slate-600">No. La suscripción de Zentivy es una tarifa plana mensual fija. No cobramos comisiones sobre el volumen de tus ventas ni cargos adicionales por facturas emitidas dentro del límite de tu plan.</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
