---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Página no encontrada — Zentivy" noindex={true}>
  <Header />
  <main class="mx-auto grid max-w-3xl place-items-center px-5 py-28 text-center">
    <p class="text-6xl font-black text-brand">404</p>
    <h1 class="mt-4 text-2xl font-black text-slate-900">
      Esta página no existe
    </h1>
    <p class="mt-3 text-slate-600">
      El enlace que seguiste no lleva a ningún lado.
    </p>
    <a
      href="/"
      class="mt-8 rounded-xl bg-brand px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-brand-dark"
      >Volver al inicio</a
    >
  </main>
  <Footer />
</Layout>
