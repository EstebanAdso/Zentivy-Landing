---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

const features = [
  {
    titulo: 'Inventario con costeo FIFO',
    desc: 'Controla existencias en tiempo real. Entradas por lotes, costo real por lote y alertas de stock bajo. Sabes cuánto ganas en cada venta.',
    icon: 'box',
  },
  {
    titulo: 'Facturación en segundos',
    desc: 'Factura de venta, creación de cotizaciones y apartados. Envía cotizaciones por email y descarga en PDF o POS 58mm. Pagos divididos.',
    icon: 'receipt',
  },
  {
    titulo: 'Clientes y cartera',
    desc: 'Historial de cada cliente, cuentas de cobro con envío por email, deudas, abonos y recordatorios. Cobra a tiempo y lleva el control.',
    icon: 'users',
  },
  {
    titulo: 'Modelos con variantes',
    desc: 'Talla, color y más. Un modelo, muchas variantes, cada una con su stock y su código de barras. Ideal para ropa y calzado.',
    icon: 'tag',
  },
  {
    titulo: 'Equipo con roles',
    desc: 'Dueño, administrador y vendedores. Cada quien ve solo lo suyo: los empleados no ven costos ni márgenes.',
    icon: 'shield',
  },
  {
    titulo: 'En la nube, desde cualquier lugar',
    desc: 'Tu negocio en el navegador. Sin instalar nada. Datos seguros y aislados por empresa. Accede desde el computador o el celular.',
    icon: 'cloud',
  },
];

const planes = [
  {
    nombre: 'Gratis',
    precio: '$0',
    periodo: 'para empezar',
    desc: 'Prueba Zentivy sin costo y monta tu inventario.',
    features: ['1 usuario', 'Inventario y facturación', 'Hasta 50 productos', 'Soporte por WhatsApp'],
    cta: 'Crear cuenta',
    destacado: false,
  },
  {
    nombre: 'Básico',
    precio: '$40.000',
    periodo: 'COP / mes',
    desc: 'Para tiendas y mini markets que ya venden a diario.',
    features: ['3 usuarios', '1.000 facturas/mes', '1.000 productos', 'Clientes, préstamos y caja', 'Soporte prioritario'],
    cta: 'Empezar ahora',
    destacado: true,
  },
  {
    nombre: 'Pro',
    precio: '$119.000',
    periodo: 'COP / mes',
    desc: 'Para negocios con varios empleados y más volumen.',
    features: ['10 usuarios', 'Facturas y productos ampliados', 'Reportes avanzados', 'Soporte dedicado'],
    cta: 'Hablar con ventas',
    destacado: false,
  },
];

const faqs = [
  {
    q: '¿Zentivy sirve para mi tienda en Colombia?',
    a: 'Sí. Zentivy está pensado para PYMES colombianas: tiendas, mini markets, papelerías, ferreterías, locales de ropa y tecnología. Maneja pesos colombianos, formato de cifras local y los flujos de venta del día a día.',
  },
  {
    q: '¿Necesito instalar algo?',
    a: 'No. Zentivy funciona 100% en la nube desde tu navegador, en computador o celular. Solo creas tu cuenta y empiezas.',
  },
  {
    q: '¿Cómo funciona el agente de WhatsApp con IA?',
    a: 'Es un servicio adicional opcional. Conectas el WhatsApp de tu negocio y un agente con inteligencia artificial responde automáticamente a tus clientes: consulta productos, verifica stock y orienta la compra. Tú decides si lo contratas.',
  },
  {
    q: '¿Zentivy hace facturación electrónica ante la DIAN?',
    a: 'No. Zentivy es una herramienta de organización y gestión interna: te ayuda a controlar inventario, ventas, cuentas de cobro y cartera. No es un software contable ni emite facturación electrónica ante la DIAN. Los documentos que genera son comprobantes de control interno de tu negocio. El cumplimiento de tus obligaciones tributarias es responsabilidad de cada empresa; te recomendamos apoyarte en tu contador.',
  },
  {
    q: '¿Mis datos están seguros?',
    a: 'Sí. Cada empresa tiene sus datos aislados de las demás. Usamos autenticación con Google y aislamiento por empresa en varias capas para que nadie vea información que no le corresponde.',
  },
  {
    q: '¿Puedo empezar gratis?',
    a: 'Sí. Tienes un plan gratuito para montar tu inventario y probar la facturación. Cuando crezcas, pasas a un plan pago sin perder tus datos.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout jsonLd={faqJsonLd}>
  <Header />

  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden">
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-b from-brand/5 to-white"
      >
      </div>
      <div class="relative mx-auto max-w-6xl px-5 py-20 text-center md:py-28 reveal">
        <p
          class="mx-auto mb-4 w-fit rounded-full border border-brand/20 bg-white px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-brand"
        >
          Software para PYMES en Colombia
        </p>
        <h1
          class="mx-auto max-w-3xl text-4xl font-black leading-tight tracking-tight text-slate-900 md:text-6xl"
        >
          El inventario y la facturación de tu negocio, <span class="text-brand"
            >en un solo lugar</span
          >
        </h1>
        <p
          class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 md:text-xl"
        >
          Controla tu stock con costeo real, factura en segundos y atiende a tus
          clientes por WhatsApp con un agente de inteligencia artificial. Pensado
          para tiendas y negocios de toda Colombia.
        </p>
        <div
          class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <a
            href={SITE.appUrl}
            class="w-full rounded-xl bg-brand px-7 py-3.5 text-base font-bold text-white shadow-lg shadow-brand/20 transition-colors hover:bg-brand-dark sm:w-auto"
            >Empezar gratis</a
          >
          <a
            href="#funciones"
            class="w-full rounded-xl border-2 border-slate-200 px-7 py-3.5 text-base font-bold text-slate-700 transition-colors hover:border-brand hover:text-brand sm:w-auto"
            >Ver funciones</a
          >
        </div>
        <p class="mt-4 text-sm text-slate-400">
          Sin tarjeta de crédito · Empieza en minutos
        </p>
      </div>
    </section>

    <!-- TRUST STRIP -->
    <section class="border-y border-slate-100 bg-white">
      <div
        class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-5 py-10 text-center md:grid-cols-4 reveal"
      >
        {
          [
            ['Costeo FIFO', 'Sabes tu ganancia real'],
            ['POS y PDF', 'Imprime como quieras'],
            ['Multi-usuario', 'Tu equipo con roles'],
            ['En la nube', 'Desde cualquier lugar'],
          ].map(([t, s]) => (
            <div>
              <p class="text-lg font-black text-slate-900">{t}</p>
              <p class="text-sm text-slate-500">{s}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- FUNCIONES -->
    <section id="funciones" class="mx-auto max-w-6xl scroll-mt-20 px-5 py-20">
      <div class="mx-auto max-w-2xl text-center reveal">
        <h2 class="text-3xl font-black tracking-tight text-slate-900 md:text-4xl">
          Todo lo que tu negocio necesita
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Un sistema de inventario y punto de venta completo, sin complicaciones.
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          features.map((f, i) => (
            <article class={`rounded-2xl border border-slate-100 bg-white p-7 transition-shadow hover:shadow-lg reveal ${i % 3 === 1 ? 'reveal-delay-1' : i % 3 === 2 ? 'reveal-delay-2' : ''}`}>
              <div class="grid h-11 w-11 place-items-center rounded-xl bg-brand/10 text-brand">
                <span class="text-xl font-black">★</span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-slate-900">{f.titulo}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{f.desc}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- AGENTE IA -->
    <section id="agente" class="scroll-mt-20 relative overflow-hidden bg-slate-50 border-t border-b border-slate-100">
      <div class="absolute inset-0 z-0 opacity-40 pointer-events-none">
        <div class="absolute top-[-20%] left-[-10%] h-[500px] w-[500px] rounded-full bg-brand-light/10 blur-[130px]"></div>
        <div class="absolute bottom-[10%] right-[-10%] h-[500px] w-[500px] rounded-full bg-brand-light/20 blur-[130px]"></div>
      </div>
      <div
        class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 px-5 py-20 md:grid-cols-2"
      >
        <div class="reveal">
          <p
            class="w-fit rounded-full bg-brand/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-brand"
          >
            Servicio adicional
          </p>
          <h2
            class="mt-4 text-3xl font-black tracking-tight text-slate-900 md:text-4xl"
          >
            Un agente de IA que atiende tu WhatsApp por ti
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-slate-600">
            Conecta el WhatsApp de tu negocio y deja que la inteligencia
            artificial responda a tus clientes: consulta tu inventario, verifica
            stock, comparte precios y orienta la compra. Tú decides cuándo
            activarlo.
          </p>
          <ul class="mt-6 space-y-3 text-slate-700">
            {
              [
                'Responde 24/7 sin que muevas un dedo.',
                'Consulta tu catálogo y stock en tiempo real.',
                'Capacidad multimodal: analiza imágenes (como comprobantes o fotos de productos) y transcribe/entiende notas de voz.',
                'WhatsApp, Messenger e Instagram.',
                'Se vende aparte: solo lo pagas si lo quieres.',
              ].map((t) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 text-brand-light">●</span>
                  <span>{t}</span>
                </li>
              ))
            }
          </ul>
          <a
            href={SITE.whatsapp}
            rel="nofollow"
            class="mt-8 inline-flex rounded-xl bg-brand px-6 py-3 text-base font-bold text-white transition-colors hover:bg-brand-dark"
            >Quiero el agente IA</a
          >
        </div>

        <div class="flex justify-center reveal w-full relative z-10">
          <!-- Mockup Celular Realista -->
          <div class="relative w-full max-w-[320px] h-[580px] bg-slate-950 rounded-[44px] p-3 shadow-2xl border-[10px] border-slate-800 ring-4 ring-slate-900/5 overflow-hidden flex flex-col text-left select-none">
            <!-- Dynamic Island / Parlante de pantalla -->
            <div class="absolute top-4 left-1/2 -translate-x-1/2 w-28 h-5 bg-slate-950 rounded-full z-30 flex items-center justify-center border border-white/5 shadow-inner">
              <div class="w-10 h-1 bg-white/10 rounded-full"></div>
            </div>
            
            <!-- Pantalla interna -->
            <div class="flex-1 bg-slate-900 rounded-[34px] overflow-hidden flex flex-col p-4 pt-8 relative">
              
              <!-- Cabecera de chat -->
              <div class="flex items-center gap-3 border-b border-white/5 pb-3 mb-3">
                <div class="h-9 w-9 rounded-full bg-brand/10 border border-brand/20 flex items-center justify-center font-bold text-brand text-xs">IA</div>
                <div>
                  <div class="text-xs font-bold text-white">Agente Zentivy</div>
                  <div class="text-[10px] text-emerald-400" id="index-agent-status">● En línea (24/7)</div>
                </div>
              </div>

              <!-- Mensajes del chat con scroll oculto y animaciones de burbuja -->
              <div class="flex-1 space-y-2.5 overflow-hidden pr-0.5 no-scrollbar text-xs" id="index-chat-container">
                <div class="chat-bubble opacity-0 max-w-[85%] rounded-2xl rounded-tl-sm bg-white/10 px-3 py-2 text-[11px] text-slate-200 transition-all duration-300 transform translate-y-2">
                  Hola, ¿tienen disco de estado sólido de 480GB?
                </div>
                
                <div class="chat-bubble opacity-0 ml-auto max-w-[85%] rounded-2xl rounded-tr-sm bg-brand p-1 text-white shadow-md transition-all duration-300 transform translate-y-2 flex flex-col gap-1">
                  <div class="relative w-full h-[95px] rounded-lg overflow-hidden border border-white/10 bg-[#f3f4f6]">
                    <img src="/zentivy_ssd.png" alt="Disco Sólido Zentivy" class="w-full h-full object-contain" />
                  </div>
                  <span class="px-2 pb-1 block text-[11px]">¡Hola! 😊 Sí, tenemos el Disco Sólido Zentivy de 480GB por $145.000 COP. Nos quedan 8 unidades en Sede Centro. ¿Te lo aparto?</span>
                </div>

                <div class="chat-bubble opacity-0 max-w-[85%] rounded-2xl rounded-tl-sm bg-white/10 px-3 py-2 text-[11px] text-slate-200 transition-all duration-300 transform translate-y-2">
                  Sí, me gusta. ¿Cómo pago?
                </div>

                <div class="chat-bubble opacity-0 ml-auto max-w-[85%] rounded-2xl rounded-tr-sm bg-brand px-3 py-2 text-[11px] text-white shadow-md transition-all duration-300 transform translate-y-2">
                  ¡Excelente! He apartado 1 unidad. Puedes pagar por Nequi al 320 000 0000 o transferir a Bancolombia. Envíame el comprobante por aquí.
                </div>
              </div>

              <div class="mt-3 border-t border-white/5 pt-3 text-[10px] text-center text-slate-500">
                Atendido automáticamente en WhatsApp
              </div>
            </div>
          </div>
        </div>

    <script>
      const initChatSimulation = () => {
        const chatContainer = document.getElementById('index-chat-container');
        const statusText = document.getElementById('index-agent-status');
        if (!chatContainer || !statusText) return;

        const bubbles = chatContainer.querySelectorAll('.chat-bubble');
        let currentStep = 0;
        let timeoutId: number;

        const showMessage = () => {
          if (currentStep >= bubbles.length) {
            // End of conversation: wait 6 seconds and restart
            timeoutId = setTimeout(() => {
              bubbles.forEach(b => {
                b.classList.add('opacity-0', 'translate-y-2');
                b.classList.remove('opacity-100', 'translate-y-0');
              });
              currentStep = 0;
              statusText.innerHTML = '● En línea (24/7)';
              statusText.className = 'text-[10px] text-emerald-400';
              chatContainer.scrollTop = 0;
              showMessage();
            }, 6000) as unknown as number;
            return;
          }

          const currentBubble = bubbles[currentStep];
          const isAgent = currentBubble.classList.contains('ml-auto');
          
          if (isAgent) {
            // Agent is typing status
            statusText.innerHTML = 'Escribiendo...';
            statusText.className = 'text-[10px] text-brand-light animate-pulse font-medium';
            
            // Wait 1.8 seconds to show the message
            timeoutId = setTimeout(() => {
              statusText.innerHTML = '● En línea (24/7)';
              statusText.className = 'text-[10px] text-emerald-400';
              
              currentBubble.classList.remove('opacity-0', 'translate-y-2');
              currentBubble.classList.add('opacity-100', 'translate-y-0');
              
              // Scroll to bottom
              chatContainer.scrollTo({
                top: chatContainer.scrollHeight,
                behavior: 'smooth'
              });
              
              currentStep++;
              // Wait 2.5 seconds before next message
              timeoutId = setTimeout(showMessage, 2500) as unknown as number;
            }, 1800) as unknown as number;
          } else {
            // Customer message: appears faster
            timeoutId = setTimeout(() => {
              currentBubble.classList.remove('opacity-0', 'translate-y-2');
              currentBubble.classList.add('opacity-100', 'translate-y-0');
              
              // Scroll to bottom
              chatContainer.scrollTo({
                top: chatContainer.scrollHeight,
                behavior: 'smooth'
              });
              
              currentStep++;
              // Wait 1.8 seconds before next message
              timeoutId = setTimeout(showMessage, 1800) as unknown as number;
            }, 1000) as unknown as number;
          }
        };

        const startSimulation = () => {
          bubbles.forEach(b => {
            b.classList.add('opacity-0', 'translate-y-2');
            b.classList.remove('opacity-100', 'translate-y-0');
          });
          currentStep = 0;
          statusText.innerHTML = '● En línea (24/7)';
          statusText.className = 'text-[10px] text-emerald-400';
          chatContainer.scrollTop = 0;
          showMessage();
        };

        startSimulation();
      };

      initChatSimulation();
      document.addEventListener('astro:after-swap', initChatSimulation);
    </script>

      </div>
    </section>

    <!-- PRECIOS -->
    <section id="precios" class="mx-auto max-w-6xl scroll-mt-20 px-5 py-20">
      <div class="mx-auto max-w-2xl text-center reveal">
        <h2 class="text-3xl font-black tracking-tight text-slate-900 md:text-4xl">
          Precios claros, sin sorpresas
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Empieza gratis y crece cuando lo necesites. Precios en pesos
          colombianos.
        </p>
      </div>

      <div class="mt-14 grid items-start gap-6 md:grid-cols-3">
        {
          planes.map((p, i) => (
            <div
              class={`rounded-2xl border p-7 reveal ${i === 1 ? 'reveal-delay-1' : i === 2 ? 'reveal-delay-2' : ''} ${p.destacado ? 'border-brand bg-white shadow-xl ring-1 ring-brand/20' : 'border-slate-100 bg-white'}`}
            >
              {p.destacado && (
                <p class="mb-3 w-fit rounded-full bg-brand px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">
                  Más popular
                </p>
              )}
              <h3 class="text-lg font-black text-slate-900">{p.nombre}</h3>
              <p class="mt-2 text-sm text-slate-500">{p.desc}</p>
              <div class="mt-5 flex items-baseline gap-1">
                <span class="text-4xl font-black text-slate-900">{p.precio}</span>
                <span class="text-sm font-medium text-slate-400">{p.periodo}</span>
              </div>
              <ul class="mt-6 space-y-2.5 text-sm text-slate-600">
                {p.features.map((f) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-0.5 font-black text-brand">✓</span>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
              <a
                href={SITE.appUrl}
                class={`mt-7 block rounded-xl px-5 py-3 text-center text-sm font-bold transition-colors ${p.destacado ? 'bg-brand text-white hover:bg-brand-dark' : 'border-2 border-slate-200 text-slate-700 hover:border-brand hover:text-brand'}`}
              >
                {p.cta}
              </a>
            </div>
          ))
        }
      </div>

      <p class="mt-8 text-center text-sm text-slate-500">
        El <strong>agente de WhatsApp con IA</strong> es un servicio adicional que
        se contrata aparte de tu plan.
        <a class="font-semibold text-brand hover:underline" href="#agente"
          >Conócelo aquí.</a
        >
      </p>
    </section>

    <!-- FAQ -->
    <section id="faq" class="scroll-mt-20 bg-slate-50">
      <div class="mx-auto max-w-3xl px-5 py-20 reveal">
        <h2
          class="text-center text-3xl font-black tracking-tight text-slate-900 md:text-4xl"
        >
          Preguntas frecuentes
        </h2>
        <div class="mt-12 space-y-4">
          {
            faqs.map((f) => (
              <div class="faq-item group rounded-2xl border border-slate-200 bg-white p-6">
                <button class="faq-trigger flex w-full cursor-pointer items-center justify-between text-base font-bold text-slate-900 text-left focus:outline-none">
                  <span>{f.q}</span>
                  <span class="faq-icon text-brand transition-transform font-bold text-xl">+</span>
                </button>
                <div class="faq-content">
                  <div class="overflow-hidden">
                    <p class="pt-3 text-sm leading-relaxed text-slate-600">{f.a}</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <script>
      const initFaqs = () => {
        const triggers = document.querySelectorAll('.faq-trigger');
        triggers.forEach(trigger => {
          trigger.addEventListener('click', () => {
            const item = trigger.closest('.faq-item');
            if (!item) return;
            const isActive = item.classList.contains('active');
            
            // Close other FAQs
            document.querySelectorAll('.faq-item').forEach(otherItem => {
              otherItem.classList.remove('active');
            });

            if (!isActive) {
              item.classList.add('active');
            }
          });
        });
      };
      
      initFaqs();
      document.addEventListener('astro:after-swap', initFaqs);
    </script>

    <!-- CTA FINAL -->
    <section class="mx-auto max-w-6xl px-5 py-20">
      <div
        class="rounded-3xl border border-brand/20 bg-gradient-to-br from-brand/5 via-white to-white p-8 md:p-16 text-center relative overflow-hidden shadow-lg reveal"
      >
        <div class="absolute -right-20 -bottom-20 h-60 w-60 rounded-full bg-brand-light/10 blur-3xl pointer-events-none"></div>
        <h2 class="text-3xl font-black tracking-tight md:text-4xl text-slate-900 relative z-10">
          Lleva tu negocio al siguiente nivel
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-slate-600 relative z-10">
          Únete a los negocios colombianos que ya controlan su inventario y
          facturan con Zentivy.
        </p>
        <a
          href={SITE.appUrl}
          class="mt-8 inline-flex rounded-xl bg-brand px-8 py-3.5 text-base font-bold text-white shadow-md transition-all hover:bg-brand-dark hover:-translate-y-0.5 relative z-10"
          >Crear mi cuenta gratis</a
        >
      </div>
    </section>
  </main>

  <Footer />
</Layout>
